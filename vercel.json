{
  "version": 2,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/public/assets/$1"
    },
    {
      "source": "/figmaAssets/(.*)",
      "destination": "/dist/public/figmaAssets/$1"
    },
    {
      "source": "/favicon.png",
      "destination": "/dist/public/favicon.png"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
