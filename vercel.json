{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "dist/public/assets/$1"
    },
    {
      "src": "/figmaAssets/(.*)",
      "dest": "dist/public/figmaAssets/$1"
    },
    {
      "src": "/favicon.png",
      "dest": "dist/public/favicon.png"
    },
    {
      "src": "/api/(.*)",
      "dest": "dist/index.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "dist/index.cjs"
    }
  ]
}
